{
  "name": "pokedex",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:init": "turbo -F @pokedex/db db:init",
    "db:emit": "turbo -F @pokedex/db db:emit",
    "db:verify": "turbo -F @pokedex/db db:verify",
    "db:sign": "turbo -F @pokedex/db db:sign",
    "db:push": "turbo -F @pokedex/db db:push",
    "db:generate": "turbo -F @pokedex/db db:generate",
    "db:migrate": "turbo -F @pokedex/db db:migrate",
    "db:studio": "turbo -F @pokedex/db db:studio"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pokedex/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "overrides": {
    "@prisma-next/postgres": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/postgres@192",
    "@prisma-next/adapter-postgres": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/adapter-postgres@192",
    "@prisma-next/core-execution-plane": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/core-execution-plane@192",
    "@prisma-next/driver-postgres": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/driver-postgres@192",
    "@prisma-next/integration-kysely": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/integration-kysely@192",
    "@prisma-next/sql-contract": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-contract@192",
    "@prisma-next/sql-orm-client": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-orm-client@192",
    "@prisma-next/sql-runtime": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-runtime@192",
    "@prisma-next/target-postgres": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/target-postgres@192",
    "@prisma-next/cli": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/cli@192",
    "@prisma-next/family-sql": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/family-sql@192",
    "@prisma-next/sql-contract-ts": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-contract-ts@192",
    "@prisma-next/contract": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/contract@192",
    "@prisma-next/contract-authoring": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/contract-authoring@192",
    "@prisma-next/utils": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/utils@192",
    "@prisma-next/core-control-plane": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/core-control-plane@192",
    "@prisma-next/ids": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/ids@192",
    "@prisma-next/operations": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/operations@192",
    "@prisma-next/runtime-executor": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/runtime-executor@192",
    "@prisma-next/sql-errors": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-errors@192",
    "@prisma-next/sql-operations": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-operations@192",
    "@prisma-next/sql-relational-core": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-relational-core@192",
    "@prisma-next/sql-schema-ir": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-schema-ir@192",
    "@prisma-next/sql-lane": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-lane@192",
    "@prisma-next/sql-lane-query-builder": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-lane-query-builder@192",
    "@prisma-next/plan": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/plan@192",
    "@prisma-next/emitter": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/emitter@192",
    "@prisma-next/sql-contract-emitter": "https://pkg.pr.new/prisma/prisma-next/@prisma-next/sql-contract-emitter@192"
  },
  "packageManager": "bun@1.3.10"
}
