{
  "name": "@prisma-next/eslint-plugin",
  "version": "0.0.1",
  "description": "ESLint plugin for Prisma Next query builder type checking and linting",
  "keywords": [
    "eslint",
    "eslintplugin",
    "prisma-next",
    "query-builder",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/3-tooling/eslint-plugin"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@typescript-eslint/types": "^8.0.0",
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-lane": "workspace:*",
    "@prisma-next/sql-relational-core": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "@types/eslint": "^9.0.0",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "*"
  }
}
