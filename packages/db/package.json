{
  "name": "@pokedex/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:emit": "prisma-next contract emit --config prisma-next.config.ts",
    "db:init": "bun run db:emit && prisma-next db init --config prisma-next.config.ts",
    "db:verify": "bun run db:emit && prisma-next db verify --config prisma-next.config.ts",
    "db:sign": "bun run db:emit && prisma-next db sign --config prisma-next.config.ts",
    "db:push": "bun run db:init",
    "db:generate": "bun run db:emit",
    "db:migrate": "bun run db:init",
    "db:studio": "echo \"Prisma Next does not include Studio. Use db:verify or a SQL GUI.\""
  },
  "dependencies": {
    "@prisma-next/adapter-postgres": "dev",
    "@prisma-next/driver-postgres": "dev",
    "@prisma-next/integration-kysely": "dev",
    "@prisma-next/postgres": "dev",
    "@prisma-next/sql-contract": "dev",
    "@prisma-next/sql-orm-client": "dev",
    "@prisma-next/sql-runtime": "dev",
    "@prisma-next/target-postgres": "dev",
    "dotenv": "catalog:",
    "kysely": "^0.28.10",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@pokedex/config": "workspace:*",
    "@prisma-next/cli": "dev",
    "@prisma-next/family-sql": "dev",
    "@prisma-next/sql-contract-psl": "dev",
    "@prisma-next/sql-contract-ts": "dev",
    "typescript": "catalog:"
  }
}
